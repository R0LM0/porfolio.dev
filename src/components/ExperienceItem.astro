---
import LinkInline from "./LinkInline.astro";

interface Props {
  role: string;
  company: string;
  summary: string;
  link?: string;
  period: string;
  location: string;
  stack: string[];
}

const { role, company, summary, link, period, location, stack } = Astro.props;
const isCurrent = period.toLowerCase().includes("actualidad") || period.toLowerCase().includes("presente");
---

<div class="relative mx-12 grid gap-8 pb-12 md:grid-cols-5 md:gap-10 before:absolute before:left-[-35px] before:block before:h-full before:border-l-2 before:border-black/20 before:content-[''] dark:before:border-white/15">
  <div class="relative md:col-span-2">
    <div class="sticky top-0 space-y-1">
      <span class="absolute -left-[42px] rounded-full text-5xl text-yellow-400">&bull;</span>
      {isCurrent && (
        <span class="inline-flex rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.28em] text-emerald-600 dark:text-emerald-300">
          Actualmente
        </span>
      )}
      <h3 class="text-xl font-bold text-yellow-500 dark:text-yellow-300">{role}</h3>
      <h4 class="text-xl font-semibold text-gray-700 dark:text-white">{company}</h4>
      <time class="block text-sm text-gray-600/80 dark:text-white/80">{period}</time>
      <p class="text-sm text-gray-600/80 dark:text-white/70">{location}</p>
    </div>
  </div>

  <div class="relative flex flex-col gap-3 text-gray-600 dark:text-gray-300 md:col-span-3">
    <p class="leading-7">{summary}</p>
    <p class="text-sm text-gray-500 dark:text-gray-400">
      <strong>Tecnologías:</strong> {stack.join(", ")}
    </p>
    {
      link && (
        <LinkInline href={link}>
          Saber más{" "}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-5 icon icon-tabler icon-tabler-chevron-right"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            fill="none"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <path stroke="none" d="M0 0h24v24H0z" fill="none" />
            <path d="M9 6l6 6l-6 6" />
          </svg>
        </LinkInline>
      )
    }
  </div>
</div>
