---
interface Props {
  label: string;
  class?: string;
}

const { label, class: className = "size-8" } = Astro.props;
const normalized = label.toLowerCase().trim();

const is = (...values: string[]) => values.includes(normalized);
---

<span
  class={`inline-flex ${className} items-center justify-center rounded-2xl border border-white/10 bg-white/10 text-white shadow-[0_10px_30px_-16px_rgba(15,23,42,0.9)] transition-colors duration-300 motion-reduce:transition-none`}
  aria-hidden="true"
>
  {
    is("react") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="24" cy="24" r="3.5" class="fill-cyan-200 stroke-cyan-200" />
        <ellipse cx="24" cy="24" rx="14" ry="5.5" class="stroke-cyan-100/90" />
        <ellipse cx="24" cy="24" rx="14" ry="5.5" transform="rotate(60 24 24)" class="stroke-cyan-100/90" />
        <ellipse cx="24" cy="24" rx="14" ry="5.5" transform="rotate(-60 24 24)" class="stroke-cyan-100/90" />
      </svg>
    )
  }
  {
    is("vite") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 10 9 26h9l-2 12 17-20h-9l5-18-12 0Z" class="fill-violet-300/20 stroke-violet-100" />
      </svg>
    )
  }
  {
    is("typescript") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="10" y="10" width="28" height="28" rx="8" class="fill-blue-500/20 stroke-blue-200/70" />
        <path d="M17 19h14" class="stroke-blue-50" />
        <path d="M17 19v3" class="stroke-blue-50" />
        <path d="M22 19v12" class="stroke-blue-50" />
        <path d="M27 19h7" class="stroke-blue-50" />
        <path d="M27 19v12" class="stroke-blue-50" />
        <path d="M31 25.5c-.8-.7-1.7-1-2.8-1-1.4 0-2.4.7-2.4 1.8 0 1 1 1.6 2.7 2.2 1.8.6 3 1.4 3 3 0 1.9-1.6 3.3-4.1 3.3-1.6 0-2.9-.5-3.8-1.4" class="stroke-blue-50" />
      </svg>
    )
  }
  {
    is("next.js", "nextjs") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="24" cy="24" r="14" class="fill-black/20 stroke-white/80" />
        <path d="M18 31V17l12 14V17" class="stroke-white" />
      </svg>
    )
  }
  {
    is("flutter") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M14 25 25 14h9L22 26l12 12h-9L14 25Z" class="fill-violet-300/20 stroke-violet-100" />
        <path d="M21 32l5-5 3 3-5 5-3-3Z" class="fill-cyan-200/25 stroke-cyan-100" />
      </svg>
    )
  }
  {
    is("dart") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 15 31 31 15 31V15Z" class="fill-sky-300/20 stroke-sky-100" />
        <path d="M15 15h12l4 4v12l-16-16Z" class="stroke-sky-100/80" />
      </svg>
    )
  }
  {
    is("android") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="13" y="16" width="22" height="18" rx="8" class="fill-emerald-300/20 stroke-emerald-100" />
        <path d="M17 16c1-4 3.5-6 7-6s6 2 7 6" class="stroke-emerald-100" />
        <path d="M19 12l-2-3M29 12l2-3" class="stroke-emerald-100" />
        <path d="M18 21h12M18 27h12" class="stroke-emerald-100" />
      </svg>
    )
  }
  {
    is(".net", ".net 8/9", "asp.net core") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="10" y="10" width="28" height="28" rx="9" class="fill-violet-400/20 stroke-violet-200/80" />
        <text x="24" y="28" text-anchor="middle" class="fill-white text-[10px] font-semibold" stroke="none">.NET</text>
      </svg>
    )
  }
  {
    is("sql server") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <ellipse cx="24" cy="14" rx="13" ry="6" class="fill-amber-300/20 stroke-amber-100" />
        <path d="M11 14v16c0 3.3 5.8 6 13 6s13-2.7 13-6V14" class="stroke-amber-100" />
        <path d="M11 22c0 3.3 5.8 6 13 6s13-2.7 13-6" class="stroke-amber-100/80" />
        <path d="M11 30c0 3.3 5.8 6 13 6s13-2.7 13-6" class="stroke-amber-100/70" />
        <text x="24" y="28" text-anchor="middle" class="fill-white text-[9px] font-semibold" stroke="none">SQL</text>
      </svg>
    )
  }
  {
    is("nestjs") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M24 10 36 17v14L24 38 12 31V17L24 10Z" class="fill-rose-400/20 stroke-rose-200/80" />
        <path d="M18 30V18l12 12V18" class="stroke-rose-50" />
      </svg>
    )
  }
  {
    is("postgresql") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <ellipse cx="24" cy="14" rx="13" ry="6" class="fill-sky-400/20 stroke-sky-200/80" />
        <path d="M11 14v16c0 3.3 5.8 6 13 6s13-2.7 13-6V14" class="stroke-sky-100" />
        <path d="M15 21c.8-2.7 3-5 8.5-5 4.2 0 7 1.6 8.5 4" class="stroke-sky-100/80" />
        <path d="M18 27h12" class="stroke-sky-100" />
        <text x="24" y="29" text-anchor="middle" class="fill-white text-[8px] font-semibold" stroke="none">PG</text>
      </svg>
    )
  }
  {
    is("docker") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <rect x="12" y="20" width="8" height="8" rx="2" class="fill-sky-300/20 stroke-sky-100" />
        <rect x="20" y="20" width="8" height="8" rx="2" class="fill-sky-300/20 stroke-sky-100" />
        <rect x="28" y="20" width="8" height="8" rx="2" class="fill-sky-300/20 stroke-sky-100" />
        <path d="M16 28h18c2 0 4 1 4 3-3 0-6 2-7 5H18c-2.5 0-4-2-4-4s1-4 2-4Z" class="stroke-sky-100" />
      </svg>
    )
  }
  {
    is("cloudflare") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M15 30h18a6 6 0 0 0 0-12 8 8 0 0 0-15-2 5 5 0 0 0-3 14Z" class="fill-orange-300/20 stroke-orange-100" />
      </svg>
    )
  }
  {
    is("git") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 16c0-2.2 1.8-4 4-4s4 1.8 4 4-1.8 4-4 4" class="stroke-rose-100" />
        <path d="M16 32c0-2.2 1.8-4 4-4s4 1.8 4 4-1.8 4-4 4-4-1.8-4-4Z" class="stroke-rose-100" />
        <path d="M24 20v8" class="stroke-rose-100" />
        <path d="M24 24h8" class="stroke-rose-100" />
        <path d="M32 24c0-2.2 1.8-4 4-4s4 1.8 4 4-1.8 4-4 4-4-1.8-4-4Z" class="stroke-rose-100" />
      </svg>
    )
  }
  {
    is("ci/cd") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M11 18h8l4 4 4-4h8" class="stroke-emerald-100" />
        <path d="M11 30h8l4-4 4 4h8" class="stroke-emerald-100" />
        <path d="M19 22v4" class="stroke-emerald-100" />
        <path d="M29 22v4" class="stroke-emerald-100" />
      </svg>
    )
  }
  {
    is("websockets") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M12 18c4 0 4 12 8 12s4-12 8-12 4 12 8 12 4-12 8-12" class="stroke-cyan-100" />
        <path d="M12 30c4 0 4-12 8-12s4 12 8 12 4-12 8-12 4 12 8 12" class="stroke-cyan-100/70" />
      </svg>
    )
  }
  {
    is("jwt") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M24 10 34 15v10c0 7-4 12-10 15-6-3-10-8-10-15V15l10-5Z" class="fill-slate-400/20 stroke-slate-100" />
        <path d="M20 25h8" class="stroke-slate-50" />
      </svg>
    )
  }
  {
    is("cookies") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M28 12a10 10 0 1 0 8 18 10 10 0 0 1-8-18Z" class="fill-amber-300/20 stroke-amber-100" />
        <circle cx="20" cy="20" r="1.8" class="fill-amber-100 stroke-amber-100" />
        <circle cx="27" cy="23" r="1.8" class="fill-amber-100 stroke-amber-100" />
        <circle cx="23" cy="29" r="1.8" class="fill-amber-100 stroke-amber-100" />
      </svg>
    )
  }
  {
    is("offline-first") && (
      <svg viewBox="0 0 48 48" class="size-full" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M16 30h15a6 6 0 0 0 0-12 8 8 0 0 0-15-2 5 5 0 0 0 0 14Z" class="stroke-slate-100" />
        <path d="M30 18l6 6-6 6" class="stroke-slate-100" />
        <path d="M32 24H16" class="stroke-slate-100" />
      </svg>
    )
  }
  {!is("react", "vite", "typescript", "next.js", "nextjs", "flutter", "dart", "android", ".net", ".net 8/9", "asp.net core", "sql server", "nestjs", "postgresql", "docker", "cloudflare", "git", "ci/cd", "websockets", "jwt", "cookies", "offline-first") && (
    <span class="text-base font-semibold tracking-[0.18em] text-white/90">
      {label
        .split(/\s+/)
        .slice(0, 2)
        .map((part) => part[0]?.toUpperCase())
        .join("")}
    </span>
  )}
</span>
