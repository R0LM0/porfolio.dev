---
import ThemeToggle from "@/components/ThemeToggle.astro";
import { navigation } from "@/data/portfolio";
---

<header
  class="fixed top-0 z-10 flex items-center justify-center w-full mx-auto mt-2"
>
  <nav
    id="header-nav"
    class="flex items-center justify-center gap-1 rounded-full px-2 py-1 text-sm font-medium backdrop-blur-md transition-colors"
  >
    {
      navigation.map((link) => (
        <a
          class:list={[
            "header-nav-link relative block rounded-full border border-transparent px-3 py-2 outline-none transition-all duration-200 focus-visible:ring-2 focus-visible:ring-sky-500/35 focus-visible:ring-offset-2",
            link.label === "r0lm0" ? "header-nav-brand font-semibold" : "",
          ]}
          data-brand={link.label === "r0lm0" ? "true" : undefined}
          data-nav-link="true"
          aria-label={link.label.toLowerCase()}
          data-section={link.href.includes("#") ? link.href.split("#")[1] : undefined}
          href={link.href}
        >
          {link.label}
        </a>
      ))
    }
    <ThemeToggle />
  </nav>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const sections = document.querySelectorAll("section")
    const navItems = document.querySelectorAll<HTMLAnchorElement>("header nav a")
    const headerNav = document.getElementById("header-nav")

    const updateScrolledState = () => {
      headerNav?.toggleAttribute("data-scrolled", window.scrollY > 12)
    }

    updateScrolledState()
    window.addEventListener("scroll", updateScrolledState, { passive: true })

    const callback = (entries: IntersectionObserverEntry[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navItems.forEach((item) => {
            const targetSection = item.getAttribute("data-section")
            const sectionId = entry.target.id.toLowerCase()
            const isActive = targetSection === sectionId

            item.toggleAttribute("data-active", isActive)
            item.setAttribute("aria-current", isActive ? "page" : "false")
          })
        }
      })
    }

    const observer = new IntersectionObserver(callback, {
      root: null,
      rootMargin: "0px",
      threshold: 0.3,
    })

    sections.forEach((section) => {
      observer.observe(section)
    })

    document.onvisibilitychange = () => {
      if (document.visibilityState === "hidden") {
        observer.disconnect()
      } else {
        sections.forEach((section) => {
          observer.observe(section)
        })
      }
    }
  })
</script>
