---
import ThemeToggle from "@/components/ThemeToggle.astro";
import { navigation } from "@/data/portfolio";
---

<header
  class="fixed top-0 z-10 flex items-center justify-center w-full mx-auto mt-2"
>
  <nav
    id="header-nav"
    class="flex items-center justify-center gap-1 rounded-full border border-slate-200/90 bg-white/92 px-2 py-1 text-sm font-medium text-slate-600 shadow-[0_10px_30px_rgba(15,23,42,0.08)] backdrop-blur-md transition-colors dark:border-slate-700/60 dark:bg-slate-900/82 dark:text-slate-300 dark:shadow-[0_16px_36px_rgba(0,0,0,0.28)]"
  >
    {
      navigation.map((link) => (
        <a
          class:list={[
            "relative block rounded-full px-3 py-2 transition-colors duration-200 outline-none",
            link.label === "r0lm0"
              ? "font-semibold text-slate-950 hover:bg-slate-950/5 hover:text-slate-950 focus-visible:bg-slate-950/5 focus-visible:text-slate-950 dark:text-white dark:hover:bg-white/10 dark:hover:text-white dark:focus-visible:bg-white/10 dark:focus-visible:text-white"
              : "text-slate-600 hover:bg-slate-100 hover:text-slate-950 focus-visible:bg-slate-100 focus-visible:text-slate-950 dark:text-slate-300 dark:hover:bg-white/10 dark:hover:text-white dark:focus-visible:bg-white/10 dark:focus-visible:text-white",
          ]}
          data-brand={link.label === "r0lm0" ? "true" : undefined}
          aria-label={link.label.toLowerCase()}
          data-section={link.href.includes("#") ? link.href.split("#")[1] : undefined}
          href={link.href}
        >
          {link.label}
        </a>
      ))
    }
    <ThemeToggle />
  </nav>
</header>

<script>
  document.addEventListener("astro:page-load", () => {
    const sections = document.querySelectorAll("section")
    const navItems = document.querySelectorAll<HTMLAnchorElement>("header nav a")

    const activeClasses = [
      "bg-sky-500/10",
      "text-sky-700",
      "dark:bg-sky-400/10",
      "dark:text-sky-300",
    ]

    const inactiveClasses = [
      "bg-transparent",
      "text-slate-600",
      "dark:text-slate-300",
    ]

    const callback = (entries: IntersectionObserverEntry[]) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navItems.forEach((item) => {
            const targetSection = item.getAttribute("data-section")
            const sectionId = entry.target.id.toLowerCase()
            const isActive = targetSection === sectionId

            item.classList.remove(...activeClasses, ...inactiveClasses)
            item.classList.add(...(isActive ? activeClasses : inactiveClasses))
            item.setAttribute("aria-current", isActive ? "true" : "false")
          })
        }
      })
    }

    const observer = new IntersectionObserver(callback, {
      root: null,
      rootMargin: "0px",
      threshold: 0.3,
    })

    sections.forEach((section) => {
      observer.observe(section)
    })

    document.onvisibilitychange = () => {
      if (document.visibilityState === "hidden") {
        observer.disconnect()
      } else {
        sections.forEach((section) => {
          observer.observe(section)
        })
      }
    }
  })
</script>
