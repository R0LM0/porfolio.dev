---
import DownloadIcon from "@/components/icons/Download.astro";
import MailIcon from "@/components/icons/Mail.astro";
import WhatsAppIcon from "@/components/icons/WhatsApp.astro";
import { site } from "@/data/portfolio";
---

<article class="relative overflow-hidden rounded-[2rem] border border-black/10 bg-white/80 p-7 shadow-[0_24px_70px_-44px_rgba(15,23,42,0.45)] backdrop-blur-sm dark:border-white/10 dark:bg-slate-900/60 sm:p-8">
  <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(34,211,238,0.14),transparent_34%),radial-gradient(circle_at_bottom_left,rgba(234,179,8,0.10),transparent_30%)]" />
  <div class="relative max-w-3xl">
    <p class="text-[0.72rem] font-semibold uppercase tracking-[0.34em] text-slate-500 dark:text-slate-400">
      Contacto directo
    </p>
    <div class="mt-3 flex flex-wrap items-start justify-between gap-4">
      <div class="max-w-2xl">
        <h3 class="text-balance text-3xl font-semibold tracking-tight text-slate-900 dark:text-white sm:text-4xl">
          Si querés hablar de .NET, frontend, Flutter o producto, escribime.
        </h3>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600 dark:text-slate-300 sm:text-base">
          Me sirve un mensaje con contexto, objetivo y alcance. En el portfolio dejé sistematizado mi stack real: React, Vite, TypeScript y Next.js en frontend; .NET + SQL Server para enterprise; NestJS + PostgreSQL para open source; y Flutter para mobile.
        </p>
      </div>
      <span class="inline-flex rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.28em] text-emerald-700 dark:text-emerald-300">
        Abierto a proyectos
      </span>
    </div>

    <div class="mt-7 grid gap-3 sm:grid-cols-3">
      <a
        class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full border border-black/10 bg-white px-4 py-3 text-sm font-medium text-slate-800 shadow-sm transition hover:-translate-y-0.5 hover:border-cyan-500/30 hover:text-cyan-700 dark:border-white/10 dark:bg-slate-950 dark:text-white dark:hover:text-cyan-300"
        href={`mailto:${site.email}`}
      >
        <MailIcon class="size-4" />
        Correo
      </a>
      <a
        class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full border border-black/10 bg-white px-4 py-3 text-sm font-medium text-slate-800 shadow-sm transition hover:-translate-y-0.5 hover:border-cyan-500/30 hover:text-cyan-700 dark:border-white/10 dark:bg-slate-950 dark:text-white dark:hover:text-cyan-300"
        href={site.whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
      >
        <WhatsAppIcon class="size-4" />
        WhatsApp
      </a>
      <a
        class="inline-flex min-h-12 items-center justify-center gap-2 rounded-full border border-black/10 bg-white px-4 py-3 text-sm font-medium text-slate-800 shadow-sm transition hover:-translate-y-0.5 hover:border-cyan-500/30 hover:text-cyan-700 dark:border-white/10 dark:bg-slate-950 dark:text-white dark:hover:text-cyan-300"
        href={site.resumeUrl}
        download={site.resumeFileName}
      >
        <DownloadIcon class="size-4" />
        Descargar CV
      </a>
    </div>

    <div class="mt-8 grid gap-3 md:grid-cols-3">
      <div class="rounded-2xl border border-black/10 bg-white/75 p-4 shadow-sm dark:border-white/10 dark:bg-white/5">
        <p class="text-[0.7rem] uppercase tracking-[0.28em] text-slate-500 dark:text-slate-400">Correo</p>
        <a class="mt-2 block text-sm font-medium text-slate-900 transition hover:text-cyan-600 dark:text-white dark:hover:text-cyan-300" href={`mailto:${site.email}`}>
          {site.email}
        </a>
      </div>
      <div class="rounded-2xl border border-black/10 bg-white/75 p-4 shadow-sm dark:border-white/10 dark:bg-white/5">
        <p class="text-[0.7rem] uppercase tracking-[0.28em] text-slate-500 dark:text-slate-400">WhatsApp</p>
        <a class="mt-2 block text-sm font-medium text-slate-900 transition hover:text-cyan-600 dark:text-white dark:hover:text-cyan-300" href={site.whatsappUrl} target="_blank" rel="noopener noreferrer">
          {site.phone}
        </a>
      </div>
      <div class="rounded-2xl border border-black/10 bg-white/75 p-4 shadow-sm dark:border-white/10 dark:bg-white/5">
        <p class="text-[0.7rem] uppercase tracking-[0.28em] text-slate-500 dark:text-slate-400">Ubicación</p>
        <p class="mt-2 text-sm font-medium text-slate-900 dark:text-white">{site.location}</p>
      </div>
    </div>
  </div>
</article>
