---
import ButtonLink from "@/components/ButtonLink.astro";
import DownloadIcon from "@/components/icons/Download.astro";
import MailIcon from "@/components/icons/Mail.astro";
import WhatsAppIcon from "@/components/icons/WhatsApp.astro";
import { site } from "@/data/portfolio";
---

<div class="grid gap-6 lg:grid-cols-[1.2fr_0.8fr]">
  <article class="relative overflow-hidden rounded-[2rem] border border-black/10 bg-white/80 p-7 shadow-[0_24px_70px_-44px_rgba(15,23,42,0.45)] backdrop-blur-sm dark:border-white/10 dark:bg-slate-900/60 sm:p-8">
    <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(34,211,238,0.14),transparent_34%),radial-gradient(circle_at_bottom_left,rgba(234,179,8,0.10),transparent_30%)]" />
    <div class="relative flex items-start justify-between gap-4">
      <div class="max-w-xl">
        <p class="text-[0.72rem] font-semibold uppercase tracking-[0.34em] text-slate-500 dark:text-slate-400">
          Contacto directo
        </p>
        <h3 class="mt-3 text-3xl font-semibold tracking-tight text-slate-900 text-balance dark:text-white sm:text-4xl">
          Si querés hablar de .NET, frontend, Flutter o producto, escribime.
        </h3>
        <p class="mt-4 max-w-2xl text-sm leading-7 text-slate-600 dark:text-slate-300 sm:text-base">
          Me sirve un mensaje con contexto, objetivo y alcance. Así te respondo con foco, sin vueltas y con una propuesta clara para avanzar.
        </p>
      </div>
      <span class="hidden rounded-full border border-emerald-500/20 bg-emerald-500/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.28em] text-emerald-700 dark:text-emerald-300 sm:inline-flex">
        Abierto a proyectos
      </span>
    </div>

    <div class="relative mt-7 grid gap-3 sm:grid-cols-3">
      <ButtonLink href={`mailto:${site.email}`} class="justify-center">
        <MailIcon class="size-4" />
        Correo
      </ButtonLink>
      <ButtonLink href={site.whatsappUrl} external class="justify-center">
        <WhatsAppIcon class="size-4" />
        WhatsApp
      </ButtonLink>
      <ButtonLink href={site.resumeUrl} download={site.resumeFileName} variant="secondary" class="justify-center">
        <DownloadIcon class="size-4" />
        Descargar CV
      </ButtonLink>
    </div>

    <div class="relative mt-8 grid gap-3 md:grid-cols-3">
      <div class="rounded-2xl border border-black/10 bg-white/75 p-4 shadow-sm dark:border-white/10 dark:bg-white/5">
        <p class="text-[0.7rem] uppercase tracking-[0.28em] text-slate-500 dark:text-slate-400">Correo</p>
        <a class="mt-2 block text-sm font-medium text-slate-900 transition hover:text-cyan-600 dark:text-white dark:hover:text-cyan-300" href={`mailto:${site.email}`}>
          {site.email}
        </a>
      </div>
      <div class="rounded-2xl border border-black/10 bg-white/75 p-4 shadow-sm dark:border-white/10 dark:bg-white/5">
        <p class="text-[0.7rem] uppercase tracking-[0.28em] text-slate-500 dark:text-slate-400">WhatsApp</p>
        <a class="mt-2 block text-sm font-medium text-slate-900 transition hover:text-cyan-600 dark:text-white dark:hover:text-cyan-300" href={site.whatsappUrl} target="_blank" rel="noopener noreferrer">
          {site.phone}
        </a>
      </div>
      <div class="rounded-2xl border border-black/10 bg-white/75 p-4 shadow-sm dark:border-white/10 dark:bg-white/5">
        <p class="text-[0.7rem] uppercase tracking-[0.28em] text-slate-500 dark:text-slate-400">Ubicación</p>
        <p class="mt-2 text-sm font-medium text-slate-900 dark:text-white">{site.location}</p>
      </div>
    </div>
  </article>

  <aside class="grid gap-4 self-stretch">
    <section class="rounded-[1.75rem] border border-slate-900/5 bg-slate-950 px-6 py-6 text-white shadow-[0_24px_70px_-44px_rgba(2,6,23,0.95)] dark:border-white/10">
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.32em] text-cyan-200/80">
        Lo que mejor puedo resolver
      </p>
      <ul class="mt-5 space-y-3 text-sm leading-7 text-slate-200">
        <li class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
          Productos web y APIs en .NET con criterio técnico.
        </li>
        <li class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
          Interfaces modernas con React, Astro o Flutter cuando hace falta móvil.
        </li>
        <li class="rounded-2xl border border-white/10 bg-white/5 px-4 py-3">
          Modernización de sistemas legados sin perder estabilidad.
        </li>
      </ul>
    </section>

    <section class="rounded-[1.75rem] border border-black/10 bg-white/75 p-6 shadow-[0_20px_60px_-40px_rgba(15,23,42,0.35)] backdrop-blur-sm dark:border-white/10 dark:bg-white/5">
      <p class="text-[0.68rem] font-semibold uppercase tracking-[0.32em] text-slate-500 dark:text-slate-400">
        Canales rápidos
      </p>
      <div class="mt-4 flex flex-wrap gap-3">
        <a class="inline-flex items-center gap-2 rounded-full border border-black/10 bg-white px-4 py-2 text-sm font-medium text-slate-800 shadow-sm transition hover:-translate-y-0.5 hover:border-cyan-500/30 hover:text-cyan-700 dark:border-white/10 dark:bg-slate-950 dark:text-white dark:hover:text-cyan-300" href={`mailto:${site.email}`}>
          <MailIcon class="size-4" />
          Escribir correo
        </a>
        <a class="inline-flex items-center gap-2 rounded-full border border-black/10 bg-white px-4 py-2 text-sm font-medium text-slate-800 shadow-sm transition hover:-translate-y-0.5 hover:border-cyan-500/30 hover:text-cyan-700 dark:border-white/10 dark:bg-slate-950 dark:text-white dark:hover:text-cyan-300" href={site.whatsappUrl} target="_blank" rel="noopener noreferrer">
          <WhatsAppIcon class="size-4" />
          Abrir WhatsApp
        </a>
        <a class="inline-flex items-center gap-2 rounded-full border border-black/10 bg-white px-4 py-2 text-sm font-medium text-slate-800 shadow-sm transition hover:-translate-y-0.5 hover:border-cyan-500/30 hover:text-cyan-700 dark:border-white/10 dark:bg-slate-950 dark:text-white dark:hover:text-cyan-300" href={site.resumeUrl} download={site.resumeFileName}>
          <DownloadIcon class="size-4" />
          Descargar CV
        </a>
      </div>
    </section>
  </aside>
</div>
