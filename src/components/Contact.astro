---
import ButtonLink from "@/components/ButtonLink.astro";
import DownloadIcon from "@/components/icons/Download.astro";
import MailIcon from "@/components/icons/Mail.astro";
import WhatsAppIcon from "@/components/icons/WhatsApp.astro";
import { site } from "@/data/portfolio";
---

<div class="grid gap-6 lg:grid-cols-[1.15fr_0.85fr]">
  <article class="rounded-3xl border border-black/10 bg-white/70 p-6 shadow-sm backdrop-blur-sm dark:border-white/10 dark:bg-white/5">
    <p class="text-xs font-semibold tracking-[0.3em] uppercase text-slate-500 dark:text-slate-400">
      Contacto directo
    </p>
    <h3 class="mt-3 text-2xl font-semibold text-slate-900 dark:text-white sm:text-3xl">
      Si querés hablar de .NET, frontend, Flutter o producto, escribime.
    </h3>
    <p class="mt-4 text-sm leading-7 text-slate-600 dark:text-slate-300 sm:text-base">
      Prefiero un mensaje claro con el contexto, el objetivo y el plazo. Podés
      escribirme por correo, WhatsApp o descargar el CV si necesitás revisar mi
      perfil completo antes de avanzar.
    </p>

    <div class="mt-6 flex flex-wrap gap-3">
      <ButtonLink href={`mailto:${site.email}`}>
        <MailIcon class="size-4" />
        Correo
      </ButtonLink>
      <ButtonLink href={site.whatsappUrl} external>
        <WhatsAppIcon class="size-4" />
        WhatsApp
      </ButtonLink>
      <ButtonLink href={site.resumeUrl} download={site.resumeFileName} variant="secondary">
        <DownloadIcon class="size-4" />
        Descargar CV
      </ButtonLink>
    </div>
  </article>

  <aside class="rounded-3xl border border-black/10 bg-slate-900 px-6 py-6 text-white shadow-[0_30px_80px_-40px_rgba(2,6,23,0.8)] dark:border-white/10 dark:bg-slate-900/70">
    <p class="text-xs font-semibold tracking-[0.3em] uppercase text-cyan-200/80">
      Datos de contacto
    </p>
    <dl class="mt-5 space-y-5">
      <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
        <dt class="text-xs uppercase tracking-[0.24em] text-slate-400">
          Correo
        </dt>
        <dd class="mt-2 text-base font-medium">
          <a class="transition hover:text-cyan-300" href={`mailto:${site.email}`}>
            {site.email}
          </a>
        </dd>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
        <dt class="text-xs uppercase tracking-[0.24em] text-slate-400">
          WhatsApp
        </dt>
        <dd class="mt-2 text-base font-medium">
          <a class="transition hover:text-cyan-300" href={site.whatsappUrl} target="_blank" rel="noopener noreferrer">
            {site.phone}
          </a>
        </dd>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
        <dt class="text-xs uppercase tracking-[0.24em] text-slate-400">
          Ubicación
        </dt>
        <dd class="mt-2 text-base font-medium">{site.location}</dd>
      </div>

      <div class="rounded-2xl border border-white/10 bg-white/5 p-4">
        <dt class="text-xs uppercase tracking-[0.24em] text-slate-400">
          Disponible para
        </dt>
        <dd class="mt-2 text-base font-medium">
          Proyectos web, APIs, Flutter y modernización de sistemas
        </dd>
      </div>
    </dl>

    <div class="mt-6 rounded-2xl border border-cyan-400/20 bg-cyan-400/10 p-4 text-sm leading-6 text-cyan-50">
      También podés pasar por
      <a href={site.linkedinUrl} target="_blank" rel="noopener noreferrer" class="font-semibold underline decoration-cyan-200/70 underline-offset-4">
        LinkedIn
      </a>
      o revisar mi
      <a href={site.githubUrl} target="_blank" rel="noopener noreferrer" class="font-semibold underline decoration-cyan-200/70 underline-offset-4">
        GitHub
      </a>
      para ver el trabajo público.
    </div>
  </aside>
</div>
