---
import Container from '@/components/Container.astro';
import SectionHeading from '@/components/SectionHeading.astro';
import { highlights } from '@/data/portfolio';
---

<Container class="py-8 sm:py-12">
  <SectionHeading
    eyebrow="Principios"
    title="Un portfolio simple no tiene por qué verse simple"
    copy="La idea es clara: dejar online algo rápido, serio y mantenible. Sin paneles innecesarios, sin complejidad artificial y sin comprometer diseño o seguridad básica."
  />

  <div class="mt-8 grid gap-4 md:grid-cols-3" data-reveal>
    {highlights.map((item) => (
      <article class="surface p-6 transition duration-300 hover:-translate-y-1 hover:border-fuchsia-400/20">
        <h3 class="text-lg font-semibold text-white">{item.title}</h3>
        <p class="mt-3 text-sm leading-7 text-slate-300">{item.description}</p>
      </article>
    ))}
  </div>
</Container>
