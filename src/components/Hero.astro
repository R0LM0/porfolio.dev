---
import Badge from "@/components/Badge.astro";
import GitHubIcon from "@/components/icons/GitHub.astro";
import LinkedInIcon from "@/components/icons/LinkedIn.astro";
import LinkIcon from "@/components/icons/Link.astro";
import MailIcon from "@/components/icons/Mail.astro";
import SocialPill from "@/components/SocialPill.astro";
import { site } from "@/data/portfolio";
---

<div class="max-w-2xl">
  <div class="flex gap-4 mb-4">
    <img
      class="rounded-full shadow-lg size-16 object-cover"
      src="/images/profile/avatar.jpg"
      alt={site.shortName}
    />
    <a
      href={site.linkedinUrl}
      target="_blank"
      rel="noopener"
      class="flex items-center transition md:justify-center md:hover:scale-105"
    >
      <Badge>{site.availabilityLabel}</Badge>
    </a>
  </div>
  <h1
    class="text-4xl font-bold tracking-tight text-gray-800 sm:text-5xl dark:text-white"
  >
    Hey, soy {site.brand}
  </h1>
  <p
    class="mt-6 text-xl text-gray-800 dark:[&>strong]:text-yellow-200 [&>strong]:text-yellow-500 [&>strong]:font-semibold dark:text-gray-300"
  >
    <strong>{site.role}</strong> desde {site.location}. {site.heroDescription}
    {` `}{site.heroHighlight}
  </p>
  <nav class="flex flex-wrap gap-4 mt-8">
    <SocialPill href="/#contact">
      <MailIcon class="size-4" />
      Contactame
    </SocialPill>
    <SocialPill href={site.linkedinUrl}>
      <LinkedInIcon class="size-4" />
      LinkedIn
    </SocialPill>
    <SocialPill href={site.githubUrl}>
      <GitHubIcon class="size-4" />
      Código y proyectos
    </SocialPill>
    <SocialPill href={site.resumeUrl}>
      <LinkIcon class="size-4" />
      CV
    </SocialPill>
  </nav>
</div>
