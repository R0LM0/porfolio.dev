---
import { skillGroups } from "@/data/portfolio";
import SkillGlyph from "@/components/icons/SkillGlyph.astro";

const tones = [
  "from-cyan-500/20 via-sky-500/10 to-transparent",
  "from-violet-500/20 via-fuchsia-500/10 to-transparent",
  "from-rose-500/20 via-orange-500/10 to-transparent",
  "from-emerald-500/20 via-teal-500/10 to-transparent",
];
---

<div class="grid gap-6 md:grid-cols-2">
  {
    skillGroups.map((group, index) => {
      const featured = group.items.slice(0, 4);
      return (
        <article class="group relative overflow-hidden rounded-3xl border border-black/10 bg-white/75 p-6 shadow-[0_20px_60px_-38px_rgba(15,23,42,0.45)] backdrop-blur-sm transition-transform duration-300 hover:-translate-y-1 dark:border-white/10 dark:bg-slate-900/60">
          <div
            class={`pointer-events-none absolute inset-0 bg-gradient-to-br ${tones[index % tones.length]} opacity-80`}
          />
          <div class="pointer-events-none absolute inset-x-0 top-0 h-px bg-white/40 dark:bg-white/10" />
          <div class="relative flex h-full flex-col">
            <div class="flex items-start justify-between gap-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-[0.32em] text-slate-500 dark:text-slate-400">
                  Pilares técnicos
                </p>
                <h3 class="mt-2 text-2xl font-semibold text-slate-900 dark:text-white">
                  {group.title}
                </h3>
              </div>
              <span class="inline-flex rounded-full border border-black/10 bg-white/70 px-3 py-1 text-xs font-medium text-slate-600 shadow-sm dark:border-white/10 dark:bg-white/5 dark:text-slate-200">
                {group.items.length} skills
              </span>
            </div>

            <p class="relative mt-4 max-w-2xl text-sm leading-7 text-slate-600 dark:text-slate-300">
              {group.description}
            </p>

            <div class="relative mt-6 grid grid-cols-4 gap-3">
              {
                featured.map((item) => (
                  <div
                    class="group/icon flex items-center justify-center rounded-2xl border border-black/10 bg-white/70 px-3 py-4 text-center shadow-sm transition-all duration-300 ease-out motion-reduce:transition-none hover:-translate-y-0.5 hover:border-cyan-500/30 hover:bg-white/90 hover:shadow-[0_16px_35px_-24px_rgba(15,23,42,0.35)] dark:border-white/10 dark:bg-white/5 dark:hover:bg-white/10"
                    aria-label={item}
                    title={item}
                  >
                    <SkillGlyph
                      label={item}
                      class="size-10 transition-transform duration-300 ease-out motion-reduce:transition-none group-hover/icon:scale-110 group-hover/icon:-rotate-3"
                    />
                  </div>
                ))
              }
            </div>

            <ul class="relative mt-6 flex flex-wrap gap-2">
              {
                group.items.map((item) => (
                  <li>
                    <span class="inline-flex rounded-full border border-black/10 bg-white/70 px-3 py-1 text-sm text-slate-700 shadow-sm transition-colors dark:border-white/10 dark:bg-white/5 dark:text-slate-200">
                      {item}
                    </span>
                  </li>
                ))
              }
            </ul>
          </div>
        </article>
      );
    })
  }
</div>
