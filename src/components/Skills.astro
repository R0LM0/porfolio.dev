---
import { skillGroups } from "@/data/portfolio";
---

<div class="grid gap-6 md:grid-cols-2 xl:grid-cols-4">
  {
    skillGroups.map((group) => (
      <article class="rounded-2xl border border-black/10 bg-white/40 p-6 shadow-sm dark:border-white/10 dark:bg-white/5">
        <h3 class="text-xl font-bold text-gray-800 dark:text-gray-100">{group.title}</h3>
        <p class="mt-3 text-gray-700 dark:text-gray-300">{group.description}</p>

        <ul class="flex flex-wrap gap-2 mt-6">
          {
            group.items.map((item) => (
              <li>
                <span class="inline-flex rounded-full border border-black/10 bg-white/60 px-3 py-1 text-sm text-gray-700 dark:border-white/10 dark:bg-white/5 dark:text-gray-200">
                  {item}
                </span>
              </li>
            ))
          }
        </ul>
      </article>
    ))
  }
</div>
