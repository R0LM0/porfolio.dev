---
import "@fontsource-variable/onest";
import "@/styles/global.css";

import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { ViewTransitions } from "astro:transitions";

interface Props {
  title: string;
  description: string;
}

const { description, title } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="darkreader-lock" />
    <ViewTransitions />
  </head>

  <body class="relative bg-stone-50 text-slate-900 dark:bg-slate-950 dark:text-white">
    <div
      class="absolute top-0 bottom-0 z-[-2] min-h-screen w-full bg-stone-50 dark:bg-slate-950
      bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(226,232,240,0.45),rgba(250,250,249,0.94))]
      dark:bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.22),rgba(15,23,42,0.98))]"
    >
    </div>
    <Header />
    <slot />
    <Footer />
    <style is:global>
      :root {
        color-scheme: light dark;
      }

      html {
        font-family: "Onest Variable", system-ui, sans-serif;
        scroll-behavior: smooth;
      }

      body {
        color: rgba(15, 23, 42, 0.92);
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        overscroll-behavior: none;
      }

      @media (prefers-reduced-motion: reduce) {
        html {
          scroll-behavior: auto;
        }
      }

      html.dark body {
        color: rgba(255, 255, 255, 0.9);
      }

      html:not(.dark) body {
        color: rgba(15, 23, 42, 0.92);
      }

      #header-nav {
        transition:
          background-color 220ms ease,
          border-color 220ms ease,
          box-shadow 220ms ease,
          color 220ms ease,
          padding 220ms ease,
          backdrop-filter 220ms ease;
      }

      html:not(.dark) #header-nav:not([data-scrolled="true"]),
      html.dark #header-nav:not([data-scrolled="true"]) {
        border-color: transparent;
        background: transparent;
        box-shadow: none;
        backdrop-filter: none;
        padding: 0;
        color: rgba(15, 23, 42, 0.94);
      }

      html:not(.dark) #header-nav[data-scrolled="true"] {
        border: 1px solid rgba(226, 232, 240, 1);
        background: linear-gradient(180deg, rgba(255, 255, 255, 0.99), rgba(248, 250, 252, 0.99));
        box-shadow: 0 16px 38px rgba(15, 23, 42, 0.1);
        color: rgba(15, 23, 42, 0.98);
        padding: 0.3rem 0.6rem;
      }

      html.dark #header-nav[data-scrolled="true"] {
        border: 1px solid rgba(71, 85, 105, 0.48);
        background: rgba(15, 23, 42, 0.82);
        box-shadow: 0 16px 36px rgba(0, 0, 0, 0.28);
        color: rgba(203, 213, 225, 0.98);
        padding: 0.3rem 0.6rem;
      }

      html:not(.dark) #header-nav a[data-nav-link] {
        color: rgba(15, 23, 42, 0.9);
      }

      html:not(.dark) #header-nav:not([data-scrolled="true"]) a[data-nav-link] {
        padding-block: 0.3rem;
      }

      html:not(.dark) #header-nav:not([data-scrolled="true"]) a[data-nav-link]:hover,
      html:not(.dark) #header-nav:not([data-scrolled="true"]) a[data-nav-link]:focus-visible {
        background: transparent;
        color: rgba(15, 23, 42, 1);
        box-shadow: inset 0 -2px 0 rgba(37, 99, 235, 0.35);
      }

      html:not(.dark) #header-nav:not([data-scrolled="true"]) a[data-nav-link][data-active="true"] {
        background: transparent;
        color: rgb(37, 99, 235);
        border-color: transparent;
        box-shadow: inset 0 -2px 0 rgba(37, 99, 235, 0.85);
      }

      html:not(.dark) #header-nav[data-scrolled="true"] a[data-nav-link] {
        color: rgba(15, 23, 42, 0.9);
      }

      html:not(.dark) #header-nav[data-scrolled="true"] a[data-nav-link]:hover,
      html:not(.dark) #header-nav[data-scrolled="true"] a[data-nav-link]:focus-visible {
        background: rgba(226, 232, 240, 1);
        color: rgba(15, 23, 42, 1);
      }

      html:not(.dark) #header-nav[data-scrolled="true"] a[data-nav-link][data-active="true"] {
        background: rgb(37, 99, 235);
        color: rgb(255, 255, 255);
        border-color: rgba(37, 99, 235, 0.75);
        box-shadow: 0 10px 22px rgba(37, 99, 235, 0.34);
      }

      html:not(.dark) #header-nav a[data-nav-link][data-brand="true"] {
        color: rgba(15, 23, 42, 1);
        font-weight: 700;
      }

      html.dark #header-nav a[data-nav-link] {
        color: rgba(203, 213, 225, 0.96);
      }

      html.dark #header-nav:not([data-scrolled="true"]) a[data-nav-link]:hover,
      html.dark #header-nav:not([data-scrolled="true"]) a[data-nav-link]:focus-visible {
        background: transparent;
        color: rgba(255, 255, 255, 1);
        box-shadow: inset 0 -2px 0 rgba(125, 211, 252, 0.35);
      }

      html.dark #header-nav:not([data-scrolled="true"]) a[data-nav-link][data-active="true"] {
        background: transparent;
        color: rgb(125, 211, 252);
        border-color: transparent;
        box-shadow: inset 0 -2px 0 rgba(125, 211, 252, 0.85);
      }

      html.dark #header-nav[data-scrolled="true"] a[data-nav-link]:hover,
      html.dark #header-nav[data-scrolled="true"] a[data-nav-link]:focus-visible {
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 1);
      }

      html.dark #header-nav[data-scrolled="true"] a[data-nav-link][data-active="true"] {
        background: rgba(56, 189, 248, 0.22);
        color: rgb(240, 249, 255);
        border-color: rgba(125, 211, 252, 0.38);
        box-shadow: 0 10px 22px rgba(2, 132, 199, 0.18);
      }

      html.dark #header-nav a[data-nav-link][data-brand="true"] {
        color: rgba(255, 255, 255, 1);
        font-weight: 700;
      }

      html:not(.dark) #header-nav:not([data-scrolled="true"]) #theme-toggle-btn {
        background: transparent;
        color: rgba(15, 23, 42, 0.9);
        box-shadow: none;
      }

      html.dark #header-nav:not([data-scrolled="true"]) #theme-toggle-btn {
        background: transparent;
        color: rgba(203, 213, 225, 1);
        box-shadow: none;
      }

      html:not(.dark) #header-nav[data-scrolled="true"] #theme-toggle-btn {
        background: rgba(248, 250, 252, 1);
        color: rgba(15, 23, 42, 0.9);
      }

      html.dark #header-nav[data-scrolled="true"] #theme-toggle-btn {
        background: rgba(30, 41, 59, 1);
        color: rgba(203, 213, 225, 1);
      }

      html:not(.dark) #header-nav[data-scrolled="true"] #theme-toggle-btn:hover,
      html:not(.dark) #header-nav[data-scrolled="true"] #theme-toggle-btn:focus-visible {
        background: rgba(226, 232, 240, 1);
        color: rgba(15, 23, 42, 1);
      }

      html.dark #header-nav[data-scrolled="true"] #theme-toggle-btn:hover,
      html.dark #header-nav[data-scrolled="true"] #theme-toggle-btn:focus-visible {
        background: rgba(51, 65, 85, 1);
        color: rgba(255, 255, 255, 1);
      }

      html:not(.dark) #themes-menu {
        border-color: rgba(226, 232, 240, 1);
        background: rgba(255, 255, 255, 1);
        box-shadow: 0 12px 30px rgba(15, 23, 42, 0.16);
      }

      html.dark #themes-menu {
        border-color: rgba(71, 85, 105, 0.6);
        background: rgba(15, 23, 42, 0.92);
        box-shadow: 0 16px 36px rgba(0, 0, 0, 0.28);
      }

      html:not(.dark) .themes-menu-option {
        color: rgba(15, 23, 42, 0.9);
      }

      html.dark .themes-menu-option {
        color: rgba(226, 232, 240, 1);
      }
    </style>
  </body>
</html>
